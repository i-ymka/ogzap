generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model OgCustomer {
  id                   String   @id @default(cuid())
  userId               String   @unique
  customerKey          String   @unique @default(cuid())
  email                String?  @unique
  plan                 OgPlan   @default(FREE)
  logoUrl              String?
  primaryColor         String   @default("#7c3aed")
  secondaryColor       String   @default("#1e293b")
  fontFamily           String   @default("Inter")
  paddleSubscriptionId String?
  imagesServed         Int      @default(0)
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt
}

model KeyRecoveryLog {
  id        String   @id @default(cuid())
  email     String
  createdAt DateTime @default(now())

  @@index([email, createdAt])
}

enum OgPlan {
  FREE
  PRO
}
